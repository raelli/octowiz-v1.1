      "<rootDir>/tests/setup-env.js"
    ]
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.7.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "eslint": "^10.5.0",
    "jest": "^29.0.0"
  }
