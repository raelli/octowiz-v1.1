{
  "name": "octowiz",
  "version": "1.1.0-alpha.1",
  "packageManager": "pnpm@10.27.0",
  "description": "Octowiz engineering control plane: Matt Pocock-first workflow routing, A2A coordination, and ephemeral local execution",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "octowiz",
    "aelli",
    "a2a",
    "engineering-control-plane",
    "mattpocock"
  ],
  "main": "index.js",
  "files": [
    "hooks/",
    "index.js",
    "src/",
    "apps/"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "start": "node index.js",
    "local": "node hooks/scripts/local-supervisor.js",
