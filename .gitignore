# Local agent workspace
.claude/worktrees/

# Octowiz engineering state: state.json and events.jsonl are durable,
# machine-independent truth and may be committed. Everything else under
# .octowiz/ (locks, temp files, repair backups, legacy setup flags) is
# machine-local and must not be shared across clones. Machine runtime state
# (PIDs, leases) lives outside the repo in ~/.cache/octowiz/.
.octowiz/*
!.octowiz/state.json
!.octowiz/events.jsonl
!.octowiz/config.json

